VITE_API_BASE_URL=http://localhost:15080

# API endpoint paths are version-controlled in `src/api/endpoints.ts`
# Keep only base URL in env.
VITE_ADMIN_SYSTEM_USER_TYPES=10
VITE_EMPLOYER_SYSTEM_USER_TYPES=20
VITE_WORKER_SYSTEM_USER_TYPES=30

# Optional client-side encryption secret for auth-session localStorage payload
VITE_AUTH_STORAGE_SECRET=
